server {
    listen 80;

    location /api/ {
        proxy_pass http://backend:8000;
        proxy_set_header Host $host;
    }

    location /admin/ {
        proxy_pass http://backend:8000;
        proxy_set_header Host $host;
    }

    location /media/ {
        alias /media/;
    }

    # Самый важный блок:
    location / {
        root /static/;
        index index.html;
        try_files $uri $uri/ /index.html;
    }
}
